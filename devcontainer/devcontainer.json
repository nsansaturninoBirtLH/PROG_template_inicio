{
  "name": "Java Classroom",
  "image": "mcr.microsoft.com/devcontainers/java:21",
  "customizations": {
    "vscode": {
      "settings": {
        // ── COPILOT ──────────────────────────────────────
        "github.copilot.enable": { "*": false },           // Sin autocompletado de IA
        "editor.inlineSuggest.enabled": false,              // Sin sugerencias inline
        "github.copilot.chat.enabled": true,                // Chat para preguntar dudas: SÍ

        // ── AUTOCOMPLETADO DEL EDITOR ───────────────────
        "editor.quickSuggestions": {
          "other": false,                                   // Sin sugerencias mientras escriben
          "comments": false,
          "strings": false
        },
        "editor.suggestOnTriggerCharacters": false,         // No sugerir al escribir "." etc.
        "editor.parameterHints.enabled": false,             // No mostrar parámetros de métodos
        "editor.acceptSuggestionOnCommitCharacter": false,  // No aceptar sugerencia con commit char
        "editor.snippetSuggestions": "none",                // Sin snippets predefinidos

        // ── CORRECCIÓN AUTOMÁTICA ───────────────────────
        "editor.autoClosingBrackets": "never",              // Que cierren llaves/paréntesis manualmente
        "editor.autoClosingQuotes": "never",                // Que cierren comillas manualmente
        "editor.autoIndent": "none",                        // Sin indentación automática
        "editor.formatOnType": false,                       // Sin formateo al escribir
        "editor.formatOnPaste": false,                      // Sin formateo al pegar
        "editor.formatOnSave": false,                       // Sin formateo al guardar

        // ── IMPORTACIONES Y QUICK FIX ───────────────────
        "editor.codeActionsOnSave": {},                     // Sin acciones automáticas al guardar
        "java.completion.enabled": false,                   // Sin autocompletado de Java
        "editor.lightbulb.enabled": "off",                  // Sin bombillita de acciones rápidas

        // ── JAVA ────────────────────────────────────────
        "java.server.launchMode": "Standard",               // Modo estándar (necesario para Run/Debug)

        // ── TERMINAL ────────────────────────────────────
        "terminal.integrated.suggestEnabled": false          // Sin sugerencias en terminal
      },
      "extensions": [
        "vscjava.vscode-java-pack",                         // Extensiones de Java
        "GitHub.copilot-chat"                                // Chat de Copilot
      ]
    }
  }
}
